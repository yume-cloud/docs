{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Yume Cloud",
  "theme": "aspen",
  "openapi": "api-reference/yume-cloud-openapi.yaml",
  "colors": {
    "primary": "#A165FD",
    "light": "#EDE8FB",
    "dark": "#151324"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://yume.cloud"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/yume-cloud"
    },
    "links": [
      {
        "label": "Войти в систему",
        "href": "https://account.yume.cloud/auth"
      },
      {
        "label": "Зарегистрироваться",
        "href": "https://account.yume.cloud/auth/register",
        "variant": "primary"
      }
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Telegram",
          "icon": "send",
          "href": "https://t.me/yumecloud"
        },
        {
          "anchor": "WhatsApp",
          "icon": "circle-phone",
          "color": {
            "light": "#25D366",
            "dark": "#25D366"
          },
          "href": "https://wa.me/77077121500"
        },
        {
          "anchor": "App Store",
          "icon": "apple",
          "color": {
            "light": "#0066CC",
            "dark": "#0066CC"
          },
          "href": "https://apps.apple.com/kz/app/yume-cloud/id6749707587"
        },
        {
          "anchor": "Google Play",
          "icon": "play",
          "href": "https://play.google.com/store/apps/details?id=com.kazbekovv.yumeweb"
        }
      ]
    },
    "languages": [
      {
        "language": "ru",
        "default": true,
        "tabs": [
          {
            "tab": "Документация",
            "groups": [
              {
                "group": "Начало работы",
                "pages": [
                  "ru/index",
                  "ru/introduction",
                  "ru/authentication",
                  "ru/quickstart"
                ]
              },
              {
                "group": "Основные понятия",
                "pages": [
                  "ru/concepts/rentals",
                  "ru/concepts/transactions",
                  "ru/concepts/billing"
                ]
              },
              {
                "group": "Руководства",
                "pages": [
                  "ru/guides/managing-rentals",
                  "ru/guides/processing-payments",
                  "ru/guides/gps-tracking",
                  "ru/guides/integrations"
                ]
              },
              {
                "group": "Настройка",
                "pages": [
                  "ru/configuration/settings",
                  "ru/configuration/access-rights",
                  "ru/configuration/notifications"
                ]
              }
            ]
          },
          {
            "tab": "Справочник API",
            "groups": [
              {
                "group": "Обзор",
                "pages": [
                  "ru/api-reference/overview",
                  "ru/api-reference/authentication"
                ]
              },
              {
                "group": "Ресурсы",
                "pages": [
                  "ru/api-reference/rentals",
                  "ru/api-reference/sales",
                  "ru/api-reference/transactions",
                  "ru/api-reference/analytics",
                  "ru/api-reference/billing",
                  "ru/api-reference/documents",
                  "ru/api-reference/attachments",
                  "ru/api-reference/gps",
                  "ru/api-reference/notifications",
                  "ru/api-reference/workshop",
                  "ru/api-reference/store",
                  "ru/api-reference/integrations",
                  "ru/api-reference/access-rights"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "thumbnails": {
    "background": "/logo/light.svg"
  },
  "api": {
    "playground": {
      "proxy": true
    }
  },
  "interaction": {
    "drilldown": false
  },
  "footer": {
    "socials": {
      "website": "https://yume.cloud",
      "instagram": "https://www.instagram.com/yumecloudx",
      "telegram": "https://t.me/beximiliano15"
    }
  }
}