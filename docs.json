{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Yume",
  "theme": "aspen",
  "openapi": "api-reference/yume-cloud-openapi.yaml",
  "colors": {
    "primary": "#A165FD",
    "light": "#EDE8FB",
    "dark": "#151324"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://yume.cloud"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Зарегистрироваться",
      "href": "https://account.yume.cloud/auth/register"
    },
    "links": [
      {
        "label": "Войти",
        "href": "https://account.yume.cloud/auth"
      }
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Telegram",
          "icon": "send",
          "href": "https://t.me/yumecloud"
        },
        {
          "anchor": "WhatsApp",
          "icon": "circle-phone",
          "color": {
            "light": "#25D366",
            "dark": "#25D366"
          },
          "href": "https://wa.me/77077121500"
        },
        {
          "anchor": "App Store",
          "icon": "apple",
          "color": {
            "light": "#0066CC",
            "dark": "#0066CC"
          },
          "href": "https://apps.apple.com/kz/app/yume-cloud/id6749707587"
        },
        {
          "anchor": "Google Play",
          "icon": "play",
          "href": "https://play.google.com/store/apps/details?id=com.kazbekovv.yumeweb"
        }
      ]
    },
    "languages": [
      {
        "language": "ru",
        "default": true,
        "tabs": [
          {
            "tab": "Документация",
            "pages": [
              "ru/obschee",
              "ru",
              "ru/main",
              {
                "group": "Основные понятия",
                "pages": [
                  "ru/concepts/client",
                  "ru/concepts/rental-point",
                  "ru/concepts/category",
                  "ru/concepts/inventory",
                  "ru/concepts/service",
                  "ru/concepts/product",
                  "ru/concepts/set",
                  "ru/concepts/custom-fields"
                ]
              },
              {
                "group": "Настройка",
                "pages": [
                  "ru/configuration/tenant",
                  "ru/configuration/rent-status",
                  "ru/configuration/labels",
                  "ru/configuration/access",
                  "ru/configuration/notifications"
                ]
              }
            ]
          },
          {
            "tab": "Модули и Интеграции",
            "pages": [
              {
                "group": "Аренда",
                "pages": [
                  "ru/modules/rent"
                ]
              },
              {
                "group": "Аренда инвентарей",
                "pages": []
              },
              {
                "group": "Аренда транспорта",
                "pages": []
              },
              {
                "group": "Продажа",
                "pages": [
                  "sklad",
                  "oprikhodyvanie",
                  "analitika"
                ]
              },
              {
                "group": "Документы",
                "pages": []
              }
            ]
          },
          {
            "tab": "Гайды",
            "pages": [
              "ru/guides/integrations",
              "ru/guides/client",
              "ru/guides/product",
              "ru/guides/rent"
            ]
          },
          {
            "tab": "Q/A",
            "pages": [
              "index"
            ]
          },
          {
            "tab": "Справочник API",
            "openapi": "api/open-api.json"
          }
        ]
      }
    ]
  },
  "thumbnails": {
    "background": "/logo/light.svg"
  },
  "banner": {
    "content": "[**Зарегистрируйтесь**](https://account.yume.cloud/auth/register) и начните использовать Yume **бесплатно**",
    "dismissible": false
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "website": "https://yume.cloud",
      "instagram": "https://www.instagram.com/yumecloudx",
      "telegram": "https://t.me/beximiliano15"
    }
  }
}